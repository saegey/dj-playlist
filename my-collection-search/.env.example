# PostgreSQL credentials (used by both the db container and DATABASE_URL)
POSTGRES_USER=djplaylist
POSTGRES_PASSWORD=djplaylistpassword
POSTGRES_DB=djplaylist
DATABASE_URL=postgres://djplaylist:djplaylistpassword@localhost:5432/djplaylist
OPENAI_API_KEY=SAMPLEOPENAIKEY
APPLE_MUSIC_TEAM_ID=sampleteamid
APPLE_MUSIC_KEY_ID=samplemusickey
# Paste the full contents of your .p8 key file here (newlines as \n)
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
DISCOGS_USER_TOKEN=discogs_user_token
DISCOGS_USERNAME=discogs_user
DISCOGS_FOLDER_ID=0
YOUTUBE_API_KEY=youtube-api-key

# Audio storage mounts (optional)
# Legacy/default behavior uses Docker named volume: music_data:/app/audio.
# To use a host path (e.g. SMB/NFS mount), set:
# APP_AUDIO_MOUNT=/Volumes/groovenet:/app/audio
# WORKER_AUDIO_MOUNT=/Volumes/groovenet:/app/audio
APP_AUDIO_MOUNT=
WORKER_AUDIO_MOUNT=

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Remote backups (restic + Backblaze B2)
# Repository format for B2: b2:<bucket-name>:<path>
# Example: b2:groovenet-backups:prod/my-collection-search
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# Job retention / queue health (seconds)
# Active/queued jobs keep a longer TTL for recovery visibility.
JOB_TTL_ACTIVE_SECONDS=604800
# Completed/failed jobs expire faster to avoid unbounded Redis growth.
JOB_TTL_TERMINAL_SECONDS=259200
