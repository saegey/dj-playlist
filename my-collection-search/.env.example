# PostgreSQL credentials (used by both the db container and DATABASE_URL)
POSTGRES_USER=djplaylist
POSTGRES_PASSWORD=djplaylistpassword
POSTGRES_DB=djplaylist
DATABASE_URL=postgres://djplaylist:djplaylistpassword@localhost:5432/djplaylist
OPENAI_API_KEY=SAMPLEOPENAIKEY
APPLE_MUSIC_TEAM_ID=sampleteamid
APPLE_MUSIC_KEY_ID=samplemusickey
APPLE_MUSIC_PRIVATE_KEY_PATH=./AuthKey_HHTf2343434.p8
MEILISEARCH_API_KEY=mysupersecretkey
MEILISEARCH_HOST=http://meili:7700
DISCOGS_USER_TOKEN=discogs_user_token
DISCOGS_USERNAME=discogs_user
DISCOGS_FOLDER_ID=0
YOUTUBE_API_KEY=youtube-api-key

# Audio storage mounts (optional)
# Legacy/default behavior uses Docker named volume: music_data:/app/audio.
# To use a host path (e.g. SMB/NFS mount), set:
# APP_AUDIO_MOUNT=/Volumes/groovenet:/app/audio
# WORKER_AUDIO_MOUNT=/Volumes/groovenet:/app/audio
# MPD_AUDIO_MOUNT=/Volumes/groovenet:/var/lib/mpd/music:ro
APP_AUDIO_MOUNT=
WORKER_AUDIO_MOUNT=
MPD_AUDIO_MOUNT=
# MPD control target for "local/DAC playback" API.
# For remote Raspberry Pi MPD, set host/ip and keep port 6600 unless customized.
# Example: MPD_HOST=raspberrypi.local
MPD_HOST=mpd
MPD_PORT=6600
# Optional prefix prepended to track filenames before sending "add" to MPD.
# Use when MPD indexes files under a subdirectory (example: "music", "library/flac").
MPD_PATH_PREFIX=

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Audio Playback Configuration (optional)
# Set to 'true' to enable audio playback features (requires USB DAC device mapping in docker-compose)
ENABLE_AUDIO_PLAYBACK=false
# ALSA device name for playback
# Run scripts/detect-audio-devices.sh to find your USB DAC card number
# Common values:
#   hw:0,0 or plughw:0,0 - Card 0 (first USB DAC)
#   hw:1,0 or plughw:1,0 - Card 1 (second USB DAC or if onboard audio is card 0)
# Use plughw for automatic format conversion (recommended)
AUDIO_DEVICE=plughw:1,0

# AirPlay Receiver Configuration (optional)
# Name that appears in iOS/Mac AirPlay menu
AIRPLAY_NAME=GrooveNET Audio
# Set to 'true' to enable bidirectional interruption between app and AirPlay
# When enabled: AirPlay pauses app playback, app playback stops AirPlay (exclusive DAC access)
# When disabled: Both services may conflict for hardware access
AIRPLAY_AUTO_PAUSE=true
# URL for shairport-sync to reach the app (default works for most setups)
# Change if using a different port or need to specify host IP
APP_URL=http://localhost:3000

# Job retention / queue health (seconds)
# Active/queued jobs keep a longer TTL for recovery visibility.
JOB_TTL_ACTIVE_SECONDS=604800
# Completed/failed jobs expire faster to avoid unbounded Redis growth.
JOB_TTL_TERMINAL_SECONDS=259200
