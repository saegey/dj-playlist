{
  "type": "module",
  "name": "my-collection-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "RUN_DB_TESTS=1 vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate": "node-pg-migrate",
    "search": "sh -c '../meilisearch --master-key=\"${MEILISEARCH_API_KEY:?Set MEILISEARCH_API_KEY}\"'",
    "psql": "docker compose exec db psql -U djplaylist -d djplaylist",
    "worker": "tsx src/workers/index.ts",
    "worker:dev": "nodemon --watch src --ext ts,js --exec 'npm run worker'",
    "backfill-identity": "tsx src/scripts/backfill-identity.ts",
    "backfill-audio-vibe": "tsx src/scripts/backfill-identity.ts -- --type=audio_vibe",
    "backfill-essentia": "tsx src/scripts/backfill-essentia.ts",
    "openapi:check": "node --import tsx/esm scripts/check-openapi.ts",
    "reindex:meili": "tsx src/scripts/reindex-meilisearch.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.33.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@sentry/nextjs": "^10.40.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "cmdk": "^1.1.1",
    "essentia.js": "^0.1.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^3.0.4",
    "meilisearch": "^0.51.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^5.23.2",
    "pg": "^8.19.0",
    "posthog-js": "^1.356.1",
    "posthog-node": "^5.21.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.35",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
