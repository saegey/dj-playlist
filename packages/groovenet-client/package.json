{
  "name": "@groovenet/client",
  "version": "1.0.0",
  "description": "Typed API client for the Groovenet DJ collection system",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": ["build/"],
  "publishConfig": { "access": "public" },
  "keywords": ["groovenet", "dj", "music", "playlist"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7"
  }
}
