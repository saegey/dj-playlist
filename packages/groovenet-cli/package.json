  "license": "MIT",
  "dependencies": {
    "@groovenet/client": "^1.0.0",
    "chalk": "^5",
    "cli-table3": "^0.6",
    "commander": "^12"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7"
  }
}
