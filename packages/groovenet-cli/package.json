{
  "name": "@groovenet/cli",
  "version": "1.0.0",
  "description": "CLI for managing your Groovenet DJ collection",
  "type": "module",
  "bin": {
    "groovenet": "build/bin/groovenet.js"
  },
  "scripts": {
